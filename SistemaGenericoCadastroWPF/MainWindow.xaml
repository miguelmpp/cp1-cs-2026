<Window x:Class="SistemaGenericoCadastroWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SistemaGenericoCadastroWPF"
        mc:Ignorable="d"
        Title="Sistema Genérico de Cadastro" Height="450" Width="700">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sistema Genérico de Cadastro - Miguel Parrado RM 554007"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Vertical">
            <TextBlock Text="ID:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtId" Height="28" Margin="0,5,0,10"/>

            <TextBlock Text="Nome:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtNome" Height="28" Margin="0,5,0,10"/>

            <TextBlock Text="Idade:" FontWeight="SemiBold"/>
            <TextBox x:Name="txtIdade" Height="28" Margin="0,5,0,10"/>
        </StackPanel>

        <WrapPanel Grid.Row="2" Margin="0,15,0,15" HorizontalAlignment="Center">
            <Button Content="Adicionar" Width="100" Margin="5" Click="BtnAdicionar_Click"/>
            <Button Content="Listar" Width="100" Margin="5" Click="BtnListar_Click"/>
            <Button Content="Buscar" Width="100" Margin="5" Click="BtnBuscar_Click"/>
            <Button Content="Remover" Width="100" Margin="5" Click="BtnRemover_Click"/>
            <Button Content="Limpar" Width="100" Margin="5" Click="BtnLimpar_Click"/>
        </WrapPanel>

        <TextBlock Grid.Row="3"
                   Text="Resultado:"
                   FontWeight="Bold"
                   Margin="0,0,0,5"/>

        <TextBox Grid.Row="4"
                 x:Name="txtResultado"
                 Margin="0,5,0,0"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"
                 IsReadOnly="True"/>
    </Grid>
</Window>